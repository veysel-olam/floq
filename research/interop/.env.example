# Layer 2 (empirical harness) config — copy to .env and fill.
# Tüm değerler ampirik round-trip içindir; statik denetim (audit*.ts) bunlara ihtiyaç duymaz.

FLOQ_API_URL=https://api.flq.social
# Better-Auth oturum çerezi — tarayıcıda giriş yap, DevTools > Network > bir /api isteği > Request Headers > cookie
FLOQ_COOKIE=

# Bağlı Bluesky handle (public feed okunur, parola gerekmez)
BLUESKY_HANDLE=

# floq Nostr kimliğinin hex public key'i (npub değil, hex)
NOSTR_NPUB_HEX=
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol

# Köprü teslimi + relay yayılımı için bekleme (ms)
DELIVERY_WAIT_MS=20000
