# ── Floq Production Environment ──────────────────────────────────────────────
# Kullanım: cp .env.production.example .env.production && nano .env.production
# Secret üret: openssl rand -hex 32

# ── Docker / Deploy ───────────────────────────────────────────────────────────
GITHUB_REPO=veyselolam/floq.com       # GitHub repo adı (GHCR image pull için)
APP_DOMAIN=floq.com                   # Ana domain (api. prefiksi otomatik eklenir)
ACME_EMAIL=admin@floq.com             # Let's Encrypt SSL bildirimleri

# ── Veritabanı ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=                    # openssl rand -hex 32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=                       # openssl rand -hex 32

# ── Şifreleme anahtarları ─────────────────────────────────────────────────────
ENCRYPTION_KEY=                       # openssl rand -hex 32
BETTER_AUTH_SECRET=                   # openssl rand -hex 32

# ── Cloudflare R2 (önerilen) ──────────────────────────────────────────────────
# Dashboard: https://dash.cloudflare.com → R2 → Create bucket "floq-media"
# API Token: R2 → Manage API Tokens → Create Token (Object Read & Write)
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=floq-media
S3_ACCESS_KEY=                        # R2 Access Key ID
S3_SECRET_KEY=                        # R2 Secret Access Key
S3_PUBLIC_URL=https://media.floq.com  # R2 custom domain (bucket'ta public access aç)

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Resend ücretsiz tier: https://resend.com (3000 email/ay)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=                            # Resend API key (re_xxxx)
SMTP_FROM=Floq <noreply@floq.com>

# ── Web Push (PWA bildirim) ───────────────────────────────────────────────────
# Üret: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=admin@floq.com

# ── Kayıt modu ───────────────────────────────────────────────────────────────
REQUIRE_INVITE=false                  # true = sadece davet koduyla kayıt
ADMIN_SECRET=                         # openssl rand -hex 16

# ── İzleme (opsiyonel) ────────────────────────────────────────────────────────
SENTRY_DSN=                           # https://sentry.io → ücretsiz tier yeterli
