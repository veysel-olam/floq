# ── Veritabanı ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=         # openssl rand -hex 24

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=            # openssl rand -hex 24

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=          # en az 8 karakter
MINIO_SECRET_KEY=          # openssl rand -hex 24
S3_PUBLIC_URL=             # https://api.floq.com/media  (API proxy üzerinden)

# ── Uygulama domain'leri ─────────────────────────────────────────────────────
APP_DOMAIN=                # api.floq.com
APP_URL=                   # https://api.floq.com
WEB_URL=                   # https://floq.com

# ── Şifreleme ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=            # openssl rand -hex 32
BETTER_AUTH_SECRET=        # openssl rand -hex 32

# ── GitHub Container Registry ────────────────────────────────────────────────
GITHUB_REPO=               # kullanici-adi/floq.com  (örn: veyselolam/floq.com)

# ── Opsiyonel ────────────────────────────────────────────────────────────────
SENTRY_DSN=
REQUIRE_INVITE=false
ADMIN_SECRET=              # openssl rand -hex 16
