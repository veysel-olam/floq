NODE_ENV=development
PORT=3001

# PostgreSQL (docker-compose ile başlatılır)
DATABASE_URL=postgresql://floq:floq@localhost:5432/floq

# Redis
REDIS_URL=redis://localhost:6379

# Uygulama
APP_DOMAIN=localhost:3001
APP_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Şifreleme — openssl rand -hex 32 ile üret
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Better Auth — openssl rand -hex 32 ile üret
BETTER_AUTH_SECRET=change_me_generate_with_openssl_rand_hex_32
BETTER_AUTH_URL=http://localhost:3001

# MinIO (docker-compose ile başlatılır)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=floq-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/floq-media

# Sentry (opsiyonel — production hata takibi)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Beta invite sistemi (opsiyonel — false ise kayıt açık)
# REQUIRE_INVITE=true
# ADMIN_SECRET=change_me_generate_with_openssl_rand_hex_16
