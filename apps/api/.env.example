NODE_ENV=development
PORT=3001

# PostgreSQL (docker-compose ile başlatılır)
DATABASE_URL=postgresql://floq:floq@localhost:5432/floq

# Redis
REDIS_URL=redis://localhost:6379

# Uygulama
APP_DOMAIN=localhost:3001
APP_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Şifreleme — openssl rand -hex 32 ile üret
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Better Auth — openssl rand -hex 32 ile üret
BETTER_AUTH_SECRET=change_me_generate_with_openssl_rand_hex_32
BETTER_AUTH_URL=http://localhost:3001

# MinIO (docker-compose ile başlatılır)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=floq-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/floq-media

# Email / SMTP (opsiyonel — ayarlanmazsa emailler konsola yazdırılır)
# Ücretsiz seçenekler: Resend (resend.com), Brevo, Mailgun
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
# SMTP_FROM=Floq <noreply@floq.social>

# Web Push Bildirimleri (opsiyonel — PWA push notification)
# Üretmek için: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_MAILTO=admin@floq.social

# GIF Arama (opsiyonel — ayarlanmazsa GIF özelliği devre dışı)
# Klipy: https://klipy.com (Tenor'un yerini aldı, Haziran 2026)
# KLIPY_API_KEY=

# Beta Davet Sistemi (opsiyonel — false ise kayıt herkese açık)
# REQUIRE_INVITE=true
# ADMIN_SECRET=change_me_generate_with_openssl_rand_hex_16

# Sentry (opsiyonel — production hata takibi)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Federation Proxy (opsiyonel — Tor veya HTTP/SOCKS5 proxy)
# FEDERATION_PROXY_URL=socks5h://127.0.0.1:9050

# Tor Hidden Service (opsiyonel)
# TOR_ONION_URL=http://youraddress.onion

# Nostr Köprüsü (opsiyonel — virgülle ayrılmış relay URL'leri)
# NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol
