# Production ortam değişkenleri — docker-compose.prod.yml için
# Bu dosyayı .env.prod olarak kopyala ve gerçek değerleri gir
# cp .env.prod.example .env.prod

# GitHub repo adı (image isimleri için: ghcr.io/GITHUB_REPO-api:latest)
GITHUB_REPO=your-org/floq.com

# Domain
APP_DOMAIN=floq.social
APP_URL=https://api.floq.social
WEB_URL=https://floq.social

# Veritabanı şifresi (güçlü bir şifre seç)
POSTGRES_PASSWORD=change_me_strong_password

# Redis şifresi
REDIS_PASSWORD=change_me_strong_password

# Şifreleme anahtarı — openssl rand -hex 32
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Auth secret — openssl rand -hex 32
BETTER_AUTH_SECRET=change_me_generate_with_openssl_rand_hex_32

# MinIO dosya depolama
MINIO_ACCESS_KEY=change_me_strong_access_key
MINIO_SECRET_KEY=change_me_strong_secret_key
S3_PUBLIC_URL=https://media.floq.social

# Admin paneli için secret (opsiyonel)
# ADMIN_SECRET=change_me_generate_with_openssl_rand_hex_16

# Beta davet sistemi (true yapılırsa kayıt sadece davetlilere açılır)
# REQUIRE_INVITE=true

# Hata takibi (opsiyonel)
# SENTRY_DSN=https://xxx@sentry.io/xxx
