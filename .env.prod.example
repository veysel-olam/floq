# Production ortam değişkenleri — docker-compose.prod.yml için
# ⚠️ Sunucuda dosya adı .env OLMALI (deploy `docker compose ... up` --env-file
# kullanmıyor, varsayılan .env okunur). Yani:
#   cp .env.prod.example .env
# (.env.prod adıyla kaydedersen değişkenler container'a GEÇMEZ)

# GitHub repo adı (image isimleri için: ghcr.io/GITHUB_REPO-api:latest)
GITHUB_REPO=your-org/floq.com

# Domain
APP_DOMAIN=floq.social
APP_URL=https://api.floq.social
WEB_URL=https://floq.social

# TLS sertifikası için (Let's Encrypt — Caddy bu mail ile sertifika alır)
ACME_EMAIL=you@example.com

# Veritabanı şifresi (güçlü bir şifre seç)
POSTGRES_PASSWORD=change_me_strong_password

# Redis şifresi
REDIS_PASSWORD=change_me_strong_password

# Şifreleme anahtarı — openssl rand -hex 32
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Auth secret — openssl rand -hex 32
BETTER_AUTH_SECRET=change_me_generate_with_openssl_rand_hex_32

# Medya depolama — sunucudaki MinIO (docker-compose.prod.yml'deki minio servisi)
# S3_ACCESS_KEY/SECRET = MinIO root kullanıcı/şifre. openssl rand -hex 16 ile üret.
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_BUCKET=floq-media
S3_ACCESS_KEY=change_me_openssl_rand_hex_16
S3_SECRET_KEY=change_me_openssl_rand_hex_24
# Public URL — Caddy media.${APP_DOMAIN} → minio:9000, bucket path dahil:
S3_PUBLIC_URL=https://media.floq.social/floq-media

# Admin paneli için secret (opsiyonel)
# ADMIN_SECRET=change_me_generate_with_openssl_rand_hex_16

# Beta davet sistemi (true yapılırsa kayıt sadece davetlilere açılır)
# REQUIRE_INVITE=true

# GIF seçici (KLIPY) — boş bırakılırsa GIF butonu sonuç döndürmez
# https://klipy.com adresinden ücretsiz anahtar
KLIPY_API_KEY=

# Hata takibi (opsiyonel)
# SENTRY_DSN=https://xxx@sentry.io/xxx
