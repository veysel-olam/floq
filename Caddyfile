{
	email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
	# ActivityPub/federation endpoints live on the apex domain (AP ids use APP_URL=https://{domain}).
	# Route them to the API; everything else is the Next.js web app.
	@federation path /.well-known/webfinger /.well-known/nodeinfo /.well-known/host-meta /.well-known/floq-verification /nodeinfo/* /users/* /actor /actor/inbox /inbox /tags/*
	reverse_proxy @federation api:3001
	reverse_proxy web:3000
}

api.{$APP_DOMAIN} {
	# CORS is handled by the API (@fastify/cors) — adding it here too would emit a
	# second Access-Control-Allow-Origin header and break credentialed requests.
	reverse_proxy api:3001
}

# Media — public object storage (MinIO). Objects live at /{bucket}/{key}.
media.{$APP_DOMAIN} {
	reverse_proxy minio:9000
}
